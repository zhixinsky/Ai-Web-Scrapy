# 复制为 .env 并填写（与 Pixian 控制台 API ID / API 密钥 一致）
# 文档：https://pixian.ai/api
# 去背景优先用采集数据中的图片公网 URL（表单 image.url）；无 URL 时才上传本地已下载文件。
PIXIAN_USER=
PIXIAN_SECRET=
# 开发测试：设为 1 即请求带 test=true（免费、结果含水印）。正式无水印请删除或注释本行并购买额度。
PIXIAN_TEST=1

# 阿里云百炼 DashScope（图像擦除补全 image-erase-completion；须中国内地北京地域 API Key）
# https://bailian.console.aliyun.com/?tab=model#/api-key
DASHSCOPE_API_KEY=

# Stability.ai（AI 消除/图片生成可选通道）
# https://platform.stability.ai/account/keys
STABILITY_API_KEY=
# 可选：用于 Stability.ai 排障与统计
# STABILITY_CLIENT_ID=my-awesome-app
# STABILITY_CLIENT_USER_ID=some-user-id
# STABILITY_CLIENT_VERSION=1.0.0
# Stability AI 消除结果格式：png | jpeg | webp
# STABILITY_ERASE_OUTPUT_FORMAT=png
## Stability.ai（当前仅用于 AI 消除 erase 通道；图片生成已统一使用千问）

# AI 涂抹消除通道：dashscope=百炼（默认）| volc=火山引擎视觉 i2i_inpainting（见项目根目录 volc.md）| tencent=腾讯云 AIART | stability=Stability.ai
# AI_ERASE_PROVIDER=dashscope
# 设为 1 / true / yes 时，主通道失败会再试另一通道（需另一套密钥已配置）
# AI_ERASE_FALLBACK=0
# 火山引擎 AK/SK（视觉 OpenAPI 签名；与控制台「访问控制」密钥一致）
# VOLC_ACCESS_KEY_ID=
# VOLC_SECRET_ACCESS_KEY=
# 兼容部分工具的环境变量名：VOLC_ACCESSKEY / VOLC_SECRETKEY

# 文本 AI 模型：mimo=小米 MiMo（默认）| openai=OpenAI 官方 API
# AI_PROVIDER=mimo
#
# 小米 MiMo 大模型（OpenAI 兼容 API；AI_PROVIDER=mimo 时使用）
# https://api.xiaomimimo.com/v1
MIMO_API_KEY=
# MIMO_BASE_URL=https://api.xiaomimimo.com/v1
# MIMO_MODEL=mimo-v2-flash
#
# OpenAI 官方 API（AI_PROVIDER=openai 时使用）
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
# 如使用代理或兼容网关可配置；官方 API 通常不需要：
# OPENAI_BASE_URL=

# 图片生成：仅千问（DashScope qwen-image-edit），不再提供通道切换。
#
# 采集上报时是否自动用默认文本 AI 处理标题与描述（1=开启，0=关闭；需已配置对应 provider 的 API Key）
# MIMO_AUTO_ENRICH=1
# 标题二次处理所用平台键（与 shared/platformPrompts 下注册一致；当前仅 amazon，占位供 Temu 等扩展）
# 当未配置导出平台目录映射、且采集未带 exportDestPlatformId 时作为回退
# MIMO_ENRICH_PLATFORM=amazon

# POST /api/collections 性能日志（默认 1）；设为 0 关闭 [collections upload] 控制台输出
# COLLECTIONS_UPLOAD_LOG=1
#
# 主图/副图单次 HTTP 拉取超时（毫秒），默认 90000；超时后该条 URL 报错并可能触发 30s 自动重试，避免远端挂死阻塞整条下载队列
# IMAGE_DOWNLOAD_FETCH_TIMEOUT_MS=90000
#
# 插件上报可选 imagesStorage: "local" | "oss"（写入 collections.images_storage；缺省/非法则 NULL，行为与 OSS_ENABLED 一致）
#
# Docker 部署时镜像默认使用 /workspace/server/chrome-extension；覆盖插件可挂载该路径或在此设绝对目录。
# COLLECTION_PLUGIN_SOURCE_DIR=

# 亚马逊等导出表格中的图片列：拼成「公网可访问」完整 URL 时使用（须含协议，无末尾斜杠）
# 未设置时由请求头 Host 推导；生产环境建议设为 https://你的域名
# PUBLIC_ORIGIN=https://example.com

# 采集图片「匿名可访问」签名密钥（用于导出表格中的 ?exp=&sig= 链接，亚马逊等平台无需登录即可拉取图片）
# 生成示例：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 未配置时导出仍为不带签名的 URL，浏览器直接打开会提示未登录。
# PUBLIC_IMAGE_SIGNING_SECRET=

# ========== 阿里云 OSS（方案 C：前端直传 + 公开读）==========
# 启用 OSS 后，服务端下载的原图/去背景产物将写入 OSS；管理端替换图片走 STS 直传 OSS。
OSS_ENABLED=0
# Bucket 所在地域（例如 oss-cn-hangzhou）
OSS_REGION=
# OSS Endpoint（例如 https://oss-cn-hangzhou.aliyuncs.com）
OSS_ENDPOINT=
# Bucket 名称
OSS_BUCKET=
# 服务端访问 OSS 的 RAM 账号 AK/SK（建议子账号最小权限）
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
# （可选）对象 key 前缀，例如 ai-web-scraper；最终 key 为 {prefix}/images/{collectionId}/{role}/{filename}
OSS_PREFIX=
# OSS 绑定的「公开读」域名（必须包含协议）。须与浏览器可访问的真实协议一致（若静态站仅 http，勿写 https）；并与 admin-ui 构建变量 VITE_OSS_PUBLIC_ORIGIN 同协议同主机，避免图片资源管理与采集详情不一致。
OSS_PUBLIC_ORIGIN=
# STS AssumeRole 的 RoleArn（仅管理端直传需要；服务端自动下载图只用 AK，不读此项）
# 须为阿里云 RAM：acs:ram::<主账号ID>:role/<角色名>（勿填 AWS 的 arn:aws:iam::...）
OSS_STS_ROLE_ARN=

## 导出模板
## 生产环境导出模板仅来自「管理端上传空模板」并持久化到服务器磁盘（uploads/export-templates/）。
